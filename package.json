{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/preinstall.mjs",
    "predev": "pnpm dlx kill-port 8080",
    "predev:backend": "pnpm run predev",
    "predev:clean": "pnpm dlx kill-port 8080 4173",
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/antenna-ui run dev",
    "dev:clean": "pnpm run predev:clean && pnpm run dev",
    "dev:backend": "pnpm --filter @workspace/api-server run dev",
    "dev:frontend": "pnpm --filter @workspace/antenna-ui run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "start": "pnpm --parallel --filter @workspace/api-server --filter @workspace/antenna-ui run start",
    "start:backend": "pnpm --filter @workspace/api-server run start",
    "start:frontend": "pnpm --filter @workspace/antenna-ui run serve",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./frontend/**\" --filter \"./backend/**\" --filter \"./shared/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@esbuild/win32-x64": "^0.27.3",
    "@rollup/rollup-win32-x64-msvc": "^4.60.1",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.2",
    "lightningcss-win32-x64-msvc": "1.31.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
